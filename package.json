    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "test": "./Taskfile.sh test",
    "prepublishOnly": "./Taskfile.sh build"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-plugin-bundle-dts": "0.3.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "queue-lit": "3.2.2"
  }
}
